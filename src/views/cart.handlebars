<h2>Carrito</h2>

{{#if products.length}}
    {{#each products}}
        <div>
            <h3>{{this.product.title}}</h3>
            <p>Precio: {{this.product.price}}</p>
            <p>Cantidad: {{this.quantify}}</p>
            <hr>
        </div>
    {{/each}}
{{else}}
    <p>El carrito está vacío</p>
{{/if}}