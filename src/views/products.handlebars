<h1>Productos</h1>

{{#each products}}
    <div>
        <h2>{{title}}</h2>
        <p>Precio: ${{price}}</p>
        <p>Description:{{description}} </p>
        <a href="/products/{{_id}}">Ver detalle</a>
    </div>
{{/each}}
<br>

{{#if hasPrevPage}}
    <a href="/products?page={{prevPage}}"> Anterior</a>
{{/if}}

{{#if hasNextPage}}
    <a href="/products?page={{nextPage}}">Siguiente</a>
{{/if}}